.DEFAULT_GOAL := build

.PHONY: all build dune-files clean

DUNE_IN_FILES := tools/dune dm/dune protocol/dune language/dune
OPAM_EXEC := $(shell if command -v opam >/dev/null 2>&1; then printf 'opam exec --'; fi)
COQC ?= $(OPAM_EXEC) coqc
ROCQ_BIN ?= $(OPAM_EXEC) rocq
DUNE ?= $(OPAM_EXEC) dune

all: build

dune-files: $(DUNE_IN_FILES)
	@version=$$(if [ "$(ROCQ)" = "1" ]; then \
		$(ROCQ_BIN) -print-version 2>/dev/null || $(COQC) -print-version; \
	else \
		$(COQC) -print-version 2>/dev/null || $(ROCQ_BIN) -print-version; \
	fi); \
	version=$${version% *}; major=$${version%%.*}; \
	if [ "$$major" = 8 ]; then rt=coq-core; else rt=rocq-runtime; fi; \
	echo "dune-files: version=$$version  $$rt.* + ppx_optcomp rocq=$$version"

%dune: %dune.in Makefile
	@chmod u+w $@ 2>/dev/null || true; \
	rm -f $@; \
	{ echo '; generated by make, do not edit'; echo; } > $@; \
	version=$$(if [ "$(ROCQ)" = "1" ]; then \
		$(ROCQ_BIN) -print-version 2>/dev/null || $(COQC) -print-version; \
	else \
		$(COQC) -print-version 2>/dev/null || $(ROCQ_BIN) -print-version; \
	fi); \
	version=$${version% *}; \
	if echo "$$version" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$$'; then \
		major_version=$${version%%.*}; version=$${version%.*}; \
	elif echo "$$version" | grep -qE '^[0-9]+\.[0-9]+(\+.*)?$$'; then \
		major_version=$${version%%.*}; \
	else \
		echo "failed to parse version $$version" >&2; exit 1; \
	fi; \
	if [ "$(ROCQ)" = "1" ]; then \
		runtime=rocq-runtime; \
	elif [ "$$major_version" = 8 ]; then \
		runtime=coq-core; \
	else \
		runtime=rocq-runtime; \
	fi; \
	sed -e "s/@@ROCQVERSION@@/$$version/g" -e "s/@@ROCQ_RUNTIME@@/$$runtime/g" $< >> $@; \
	chmod a-w $@

build: dune-files
	@$(DUNE) build --root . --profile dev tools/vsrocq_split_sentences.exe

clean:
	$(DUNE) clean --root .
	rm -f $(DUNE_IN_FILES)
