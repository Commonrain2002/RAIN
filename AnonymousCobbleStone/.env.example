# use `linux/arm64` if your'e on an M1 mac
DOCKER_PLATFORM=linux/amd64

# DeepSeek (OpenAI-compatible). Use with: -o deepseek-v4-flash
DEEPSEEK_API_KEY=<api key>
# Optional; default is https://api.deepseek.com (code appends /v1)
# DEEPSEEK_API_BASE=https://api.deepseek.com

# OpenAI (optional if using DeepSeek)
OPENAI_ORG=
OPENAI_SECRET=

PROJECTS_ROOT=coq-projects

LOG_LEVEL=INFO
LOG_FILE=logs
LOG_LEVELS_FILE=log_levels.yaml

# LLM prompt limits (deepseek-v4-flash context 1M; keep prompt + completion under that)
# MAX_OBSERVATION_TOKENS=128000
# MAX_CHAT_COMPLETION_TOKENS=300000
# LLM_REQUEST_TIMEOUT_SEC=600
# Goal decomposition: per-lemma cumulative wall-clock cap (seconds); resume adds to example_wall_times.json
# GOAL_DECOMPOSITION_EXAMPLE_WALL_TIMEOUT_SEC=5400
# LLM_MAX_RETRIES=50
# DeepSeek thinking mode: reasoning_effort (high|max); see thinking_mode API guide
# DEEPSEEK_REASONING_EFFORT=max
# Optional local tokenizer for DeepSeek prompt-size estimates.
# DEEPSEEK_TOKENIZER_DIR=deepseek_v3_tokenizer
# SSH_DIRECTORY=~/.ssh
# CONTAINER_SSH_DIRECTORY=/workspace/.ssh

TOGETHER_API_KEY=

OCTO_API_KEY=

CLAUDE_API_KEY=
